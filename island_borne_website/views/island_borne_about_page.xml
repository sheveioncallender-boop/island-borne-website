<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="island_borne_about_page_template" name="Island Borne About Page">
        <t t-call="website.layout">
            <t t-set="title">About Island Borne</t>
            <t t-set="additional_title">About Island Borne</t>
            <div id="wrap" class="oe_structure ib-about-page">
                <main class="ib-about-main">
                    <section class="ib-about-hero" aria-labelledby="ib-about-title">
                        <div class="ib-about-hero-copy">
                            <p class="ib-about-kicker">OUR STORY</p>
                            <h1 id="ib-about-title">made for<br/>real life</h1>
                            <p class="ib-about-hero-lead">Island Borne is feel-good skincare that keeps things simple: rich moisture, tropical fragrance and everyday prices that make a little indulgence easy.</p>
                            <a class="ib-pill-button" href="/products">MEET THE RANGE</a>
                        </div>
                        <div class="ib-about-hero-visual" aria-label="Island Borne products among tropical leaves">
                            <img class="ib-about-leaf-image" src="/island_borne_website/static/src/img/about_tropical.webp" alt="Sunlit tropical leaves" fetchpriority="high"/>
                            <div class="ib-about-bottle-cluster" aria-hidden="true">
                                <img class="ib-about-bottle ib-about-bottle-cool" src="/island_borne_website/static/src/img/cool_lotion.webp" alt=""/>
                                <img class="ib-about-bottle ib-about-bottle-juicy" src="/island_borne_website/static/src/img/juicy_shower.webp" alt=""/>
                                <img class="ib-about-bottle ib-about-bottle-yummy" src="/island_borne_website/static/src/img/yummy_lotion.webp" alt=""/>
                            </div>
                        </div>
                    </section>

                    <section class="ib-about-belief" aria-labelledby="ib-about-belief-title">
                        <div class="ib-about-belief-art">
                            <span class="ib-about-orbit ib-about-orbit-one"></span>
                            <span class="ib-about-orbit ib-about-orbit-two"></span>
                            <img src="/island_borne_website/static/src/img/island_borne_icon.svg" alt="Island Borne icon" loading="lazy"/>
                            <p>born<br/>to shine</p>
                        </div>
                        <div class="ib-about-belief-copy">
                            <p class="ib-about-kicker">WHAT WE BELIEVE</p>
                            <h2 id="ib-about-belief-title">A LITTLE LOVE FOR EVERY BODY.</h2>
                            <p>We believe that taking care of your skin should feel joyful, uncomplicated and within reach. That is why Island Borne creates everyday skincare designed to leave your skin feeling soft, refreshed and ready to shine.</p>
                            <p>Our products bring together moisture, invigorating fragrances and thoughtful packaging in a routine that feels like a treat and fits into real life.</p>
                        </div>
                    </section>

                    <section class="ib-about-values" aria-labelledby="ib-about-values-title">
                        <div class="ib-about-values-heading">
                            <p class="ib-about-kicker">THE ISLAND BORNE WAY</p>
                            <h2 id="ib-about-values-title">what makes us shine</h2>
                        </div>
                        <div class="ib-about-values-grid">
                            <article class="ib-about-value-card ib-about-value-cool">
                                <div class="ib-about-value-icon">
                                    <img src="/island_borne_website/static/src/img/cool_icon.svg" alt="" loading="lazy"/>
                                </div>
                                <h3>FEEL-GOOD MOISTURE</h3>
                                <p>Everyday care made to help skin feel soft, comfortable and refreshed.</p>
                            </article>
                            <article class="ib-about-value-card ib-about-value-juicy">
                                <div class="ib-about-value-icon">
                                    <img src="/island_borne_website/static/src/img/juicy_icon.svg" alt="" loading="lazy"/>
                                </div>
                                <h3>TROPICAL ENERGY</h3>
                                <p>Juicy, yummy and cool fragrances that turn an ordinary routine into a brighter moment.</p>
                            </article>
                            <article class="ib-about-value-card ib-about-value-yummy">
                                <div class="ib-about-value-icon">
                                    <img src="/island_borne_website/static/src/img/yummy_icon.svg" alt="" loading="lazy"/>
                                </div>
                                <h3>EVERYDAY VALUE</h3>
                                <p>Skincare that feels special without the hefty price tag.</p>
                            </article>
                            <article class="ib-about-value-card ib-about-value-earth">
                                <div class="ib-about-value-mark" aria-hidden="true">+</div>
                                <h3>THOUGHTFUL PACKAGING</h3>
                                <p>A more considered approach to packaging you can feel good about.</p>
                            </article>
                        </div>
                    </section>

                    <section class="ib-about-routine" aria-labelledby="ib-about-routine-title">
                        <div class="ib-about-routine-copy">
                            <p class="ib-about-kicker">YOUR EVERYDAY ROUTINE</p>
                            <h2 id="ib-about-routine-title">clean, smooth,<br/>step out and shine</h2>
                            <p>Start with Clean, Clean Shower Gel, follow with Smooth, Smooth Lotion and finish with the fragrance that feels most like you.</p>
                            <div class="ib-about-routine-actions">
                                <a class="ib-pill-button" href="/products">SEE PRODUCTS</a>
                                <a class="ib-about-text-link" href="/fragrances">PICK YOUR SCENT <span aria-hidden="true">&#8594;</span></a>
                            </div>
                        </div>
                        <div class="ib-about-routine-products" aria-label="Island Borne shower gel and lotion range">
                            <div class="ib-about-routine-product ib-about-routine-product-one">
                                <img src="/island_borne_website/static/src/img/cool_shower.webp" alt="Cool Clean Clean Shower Gel" loading="lazy"/>
                                <span>COOL</span>
                            </div>
                            <div class="ib-about-routine-product ib-about-routine-product-two">
                                <img src="/island_borne_website/static/src/img/juicy_lotion.webp" alt="Juicy Smooth Smooth Lotion" loading="lazy"/>
                                <span>JUICY</span>
                            </div>
                            <div class="ib-about-routine-product ib-about-routine-product-three">
                                <img src="/island_borne_website/static/src/img/yummy_shower.webp" alt="Yummy Clean Clean Shower Gel" loading="lazy"/>
                                <span>YUMMY</span>
                            </div>
                        </div>
                    </section>

                    <section class="ib-about-cta" aria-labelledby="ib-about-cta-title">
                        <div class="ib-about-cta-overlay"></div>
                        <div class="ib-about-cta-content">
                            <p class="ib-about-kicker">FIND YOUR ISLAND BORNE</p>
                            <h2 id="ib-about-cta-title">ready to find<br/>your scent?</h2>
                            <p>Discover Juicy, Yummy and Cool, then find your nearest Island Borne retailer.</p>
                            <a class="ib-pill-button ib-about-cta-button" href="/#store-finder">FIND A RETAILER</a>
                        </div>
                    </section>
                </main>
            </div>
        </t>
    </template>

    <record id="island_borne_about_page" model="website.page">
        <field name="name">About Island Borne</field>
        <field name="url">/about</field>
        <field name="view_id" ref="island_borne_about_page_template"/>
        <field name="is_published">True</field>
        <field name="website_indexed">True</field>
    </record>
</odoo>
