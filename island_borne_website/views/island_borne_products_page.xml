<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="island_borne_products_page_template" name="Island Borne Products Page">
        <t t-call="website.layout">
            <t t-set="title">Island Borne Products</t>
            <t t-set="additional_title">Products</t>
            <div id="wrap" class="oe_structure ib-products-page">
                <main class="ib-products-page-main">
                    <section class="ib-products-page-hero" aria-labelledby="ib-products-page-title">
                        <div class="ib-products-page-hero-copy">
                            <p class="ib-products-page-kicker">OUR PRODUCTS</p>
                            <h1 id="ib-products-page-title">clean, smooth,<br/>step out and shine</h1>
                            <p>Two everyday essentials, three tropical moods and one simple routine made to leave your skin feeling fresh, soft and ready for whatever comes next.</p>
                            <a class="ib-pill-button" href="#ib-product-range">EXPLORE THE RANGE</a>
                        </div>
                        <div class="ib-products-page-hero-visual" aria-label="Island Borne shower gels and lotions among tropical leaves">
                            <img class="ib-products-page-leaves" src="/island_borne_website/static/src/img/about_tropical_wide.webp" alt="Tropical green leaves" fetchpriority="high"/>
                            <div class="ib-products-page-hero-bottles" aria-hidden="true">
                                <img class="ib-products-page-hero-bottle ib-products-page-hero-bottle-one" src="/island_borne_website/static/src/img/cool_shower.webp" alt=""/>
                                <img class="ib-products-page-hero-bottle ib-products-page-hero-bottle-two" src="/island_borne_website/static/src/img/juicy_lotion.webp" alt=""/>
                                <img class="ib-products-page-hero-bottle ib-products-page-hero-bottle-three" src="/island_borne_website/static/src/img/yummy_shower.webp" alt=""/>
                            </div>
                        </div>
                    </section>

                    <section class="ib-products-routine-intro" aria-labelledby="ib-products-routine-title">
                        <div class="ib-products-routine-heading">
                            <p class="ib-products-page-kicker">YOUR EVERYDAY ROUTINE</p>
                            <h2 id="ib-products-routine-title">two simple steps.<br/>one feel-good ritual.</h2>
                        </div>
                        <div class="ib-products-routine-steps">
                            <article>
                                <span>01</span>
                                <div>
                                    <h3>CLEAN, CLEAN</h3>
                                    <p>Start fresh with a tropical shower gel that turns your everyday cleanse into a brighter moment.</p>
                                </div>
                            </article>
                            <article>
                                <span>02</span>
                                <div>
                                    <h3>SMOOTH, SMOOTH</h3>
                                    <p>Follow with lotion for feel-good moisture and skin that feels soft, comfortable and ready to shine.</p>
                                </div>
                            </article>
                        </div>
                    </section>

                    <section id="ib-product-range" class="ib-products-family ib-products-family-clean" aria-labelledby="ib-clean-clean-title">
                        <div class="ib-products-family-heading">
                            <div>
                                <p class="ib-products-page-kicker">STEP ONE</p>
                                <h2 id="ib-clean-clean-title">clean, clean</h2>
                            </div>
                            <p class="ib-products-family-description">A fresh, feel-good shower gel available in three Island Borne fragrance moods.</p>
                        </div>
                        <div class="ib-products-detail-grid">
                            <article class="ib-products-detail-card ib-products-detail-cool">
                                <div class="ib-products-detail-scent">
                                    <img src="/island_borne_website/static/src/img/cool_icon.svg" alt=""/>
                                    <div><strong>COOL</strong><span>Tropical fresh water</span></div>
                                </div>
                                <div class="ib-products-detail-bottle-wrap">
                                    <span class="ib-products-detail-orbit" aria-hidden="true"></span>
                                    <img class="ib-products-detail-bottle" src="/island_borne_website/static/src/img/cool_shower.webp" alt="Cool Clean Clean Shower Gel" loading="lazy"/>
                                </div>
                                <div class="ib-products-detail-copy">
                                    <h3>COOL CLEAN, CLEAN</h3>
                                    <p>Shower Gel <span>|</span> 300ml</p>
                                </div>
                            </article>
                            <article class="ib-products-detail-card ib-products-detail-juicy">
                                <div class="ib-products-detail-scent">
                                    <img src="/island_borne_website/static/src/img/juicy_icon.svg" alt=""/>
                                    <div><strong>JUICY</strong><span>Tropical fruity</span></div>
                                </div>
                                <div class="ib-products-detail-bottle-wrap">
                                    <span class="ib-products-detail-orbit" aria-hidden="true"></span>
                                    <img class="ib-products-detail-bottle" src="/island_borne_website/static/src/img/juicy_shower.webp" alt="Juicy Clean Clean Shower Gel" loading="lazy"/>
                                </div>
                                <div class="ib-products-detail-copy">
                                    <h3>JUICY CLEAN, CLEAN</h3>
                                    <p>Shower Gel <span>|</span> 300ml</p>
                                </div>
                            </article>
                            <article class="ib-products-detail-card ib-products-detail-yummy">
                                <div class="ib-products-detail-scent">
                                    <img src="/island_borne_website/static/src/img/yummy_icon.svg" alt=""/>
                                    <div><strong>YUMMY</strong><span>Vanilla coconut</span></div>
                                </div>
                                <div class="ib-products-detail-bottle-wrap">
                                    <span class="ib-products-detail-orbit" aria-hidden="true"></span>
                                    <img class="ib-products-detail-bottle" src="/island_borne_website/static/src/img/yummy_shower.webp" alt="Yummy Clean Clean Shower Gel" loading="lazy"/>
                                </div>
                                <div class="ib-products-detail-copy">
                                    <h3>YUMMY CLEAN, CLEAN</h3>
                                    <p>Shower Gel <span>|</span> 300ml</p>
                                </div>
                            </article>
                        </div>
                    </section>

                    <section class="ib-products-family ib-products-family-smooth" aria-labelledby="ib-smooth-smooth-title">
                        <div class="ib-products-family-heading">
                            <div>
                                <p class="ib-products-page-kicker">STEP TWO</p>
                                <h2 id="ib-smooth-smooth-title">smooth, smooth</h2>
                            </div>
                            <p class="ib-products-family-description">Everyday lotion with a soft, comfortable finish in the same three tropical fragrance moods.</p>
                        </div>
                        <div class="ib-products-detail-grid">
                            <article class="ib-products-detail-card ib-products-detail-cool">
                                <div class="ib-products-detail-scent">
                                    <img src="/island_borne_website/static/src/img/cool_icon.svg" alt=""/>
                                    <div><strong>COOL</strong><span>Tropical fresh water</span></div>
                                </div>
                                <div class="ib-products-detail-bottle-wrap">
                                    <span class="ib-products-detail-orbit" aria-hidden="true"></span>
                                    <img class="ib-products-detail-bottle" src="/island_borne_website/static/src/img/cool_lotion.webp" alt="Cool Smooth Smooth Lotion" loading="lazy"/>
                                </div>
                                <div class="ib-products-detail-copy">
                                    <h3>COOL SMOOTH, SMOOTH</h3>
                                    <p>Lotion <span>|</span> 300ml</p>
                                </div>
                            </article>
                            <article class="ib-products-detail-card ib-products-detail-juicy">
                                <div class="ib-products-detail-scent">
                                    <img src="/island_borne_website/static/src/img/juicy_icon.svg" alt=""/>
                                    <div><strong>JUICY</strong><span>Tropical fruity</span></div>
                                </div>
                                <div class="ib-products-detail-bottle-wrap">
                                    <span class="ib-products-detail-orbit" aria-hidden="true"></span>
                                    <img class="ib-products-detail-bottle" src="/island_borne_website/static/src/img/juicy_lotion.webp" alt="Juicy Smooth Smooth Lotion" loading="lazy"/>
                                </div>
                                <div class="ib-products-detail-copy">
                                    <h3>JUICY SMOOTH, SMOOTH</h3>
                                    <p>Lotion <span>|</span> 300ml</p>
                                </div>
                            </article>
                            <article class="ib-products-detail-card ib-products-detail-yummy">
                                <div class="ib-products-detail-scent">
                                    <img src="/island_borne_website/static/src/img/yummy_icon.svg" alt=""/>
                                    <div><strong>YUMMY</strong><span>Vanilla coconut</span></div>
                                </div>
                                <div class="ib-products-detail-bottle-wrap">
                                    <span class="ib-products-detail-orbit" aria-hidden="true"></span>
                                    <img class="ib-products-detail-bottle" src="/island_borne_website/static/src/img/yummy_lotion.webp" alt="Yummy Smooth Smooth Lotion" loading="lazy"/>
                                </div>
                                <div class="ib-products-detail-copy">
                                    <h3>YUMMY SMOOTH, SMOOTH</h3>
                                    <p>Lotion <span>|</span> 300ml</p>
                                </div>
                            </article>
                        </div>
                    </section>

                    <section class="ib-products-benefits" aria-labelledby="ib-products-benefits-title">
                        <div class="ib-products-benefits-heading">
                            <p class="ib-products-page-kicker">WHY YOU'LL LOVE THEM</p>
                            <h2 id="ib-products-benefits-title">made to feel like a treat</h2>
                        </div>
                        <div class="ib-products-benefits-grid">
                            <article>
                                <span class="ib-products-benefit-mark">+</span>
                                <h3>EVERYDAY MOISTURE</h3>
                                <p>A simple shower-to-lotion routine created for soft, refreshed-feeling skin.</p>
                            </article>
                            <article>
                                <span class="ib-products-benefit-mark">*</span>
                                <h3>TROPICAL FRAGRANCE</h3>
                                <p>Three distinctive scent moods designed to bring island energy to your day.</p>
                            </article>
                            <article>
                                <img src="/island_borne_website/static/src/img/island_borne_icon.svg" alt=""/>
                                <h3>REAL-LIFE VALUE</h3>
                                <p>Feel-good skincare made to fit into everyday life without the hefty price tag.</p>
                            </article>
                        </div>
                    </section>

                    <section class="ib-products-scent-cta" aria-labelledby="ib-products-scent-title">
                        <img class="ib-products-scent-cta-bg" src="/island_borne_website/static/src/img/about_tropical_wide.webp" alt="" loading="lazy"/>
                        <div class="ib-products-scent-cta-overlay"></div>
                        <div class="ib-products-scent-cta-copy">
                            <p class="ib-products-page-kicker">THREE MOODS. YOUR PICK.</p>
                            <h2 id="ib-products-scent-title">which scent<br/>feels like you?</h2>
                            <p>Go juicy, keep it cool or make it yummy. Meet all three Island Borne fragrances.</p>
                            <a class="ib-pill-button ib-products-scent-button" href="/fragrances">PICK YOUR SCENT</a>
                        </div>
                        <div class="ib-products-scent-icons" aria-hidden="true">
                            <div><img src="/island_borne_website/static/src/img/cool_icon.svg" alt=""/><span>COOL</span></div>
                            <div><img src="/island_borne_website/static/src/img/juicy_icon.svg" alt=""/><span>JUICY</span></div>
                            <div><img src="/island_borne_website/static/src/img/yummy_icon.svg" alt=""/><span>YUMMY</span></div>
                        </div>
                    </section>

                    <section class="ib-products-retailer-cta" aria-labelledby="ib-products-retailer-title">
                        <div>
                            <p class="ib-products-page-kicker">READY TO SHINE?</p>
                            <h2 id="ib-products-retailer-title">find Island Borne near you</h2>
                        </div>
                        <a class="ib-pill-button" href="/#store-finder">FIND A RETAILER</a>
                    </section>
                </main>
            </div>
        </t>
    </template>

    <record id="island_borne_products_page" model="website.page">
        <field name="name">Island Borne Products</field>
        <field name="url">/products</field>
        <field name="view_id" ref="island_borne_products_page_template"/>
        <field name="is_published">True</field>
        <field name="website_indexed">True</field>
    </record>
</odoo>
