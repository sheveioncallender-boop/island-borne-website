<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        This published website.page is registered directly at `/`. A controller
        fallback in controllers/main.py also guarantees that the Island Borne
        design remains the website entry point even when a database contains a
        stale homepage_url value.
    -->
    <template id="island_borne_homepage_page_template" name="Island Borne Homepage Page">
        <t t-call="website.layout">
            <t t-set="title">Island Borne</t>
            <t t-set="additional_title">Island Borne</t>
            <div id="wrap" class="oe_structure ib-homepage">
                <main class="ib-home-main">
                    <section class="ib-hero" aria-labelledby="ib-page-hero-title">
                        <div class="ib-hero-copy">
                            <div class="ib-hero-copy-inner">
                                <h1 id="ib-page-hero-title">borne<br/>to shine</h1>
                                <p>At Island Borne, we believe that every body and every budget deserves a little love. That’s why we create skincare that’s all about feeling good in your own skin, without the hefty price tag.</p>
                                <a class="ib-pill-button" href="#store-finder">FIND A RETAILER</a>
                            </div>
                        </div>
                        <picture class="ib-hero-picture">
                            <source media="(max-width: 767px)" srcset="/island_borne_website/static/src/img/hero_mobile.png"/>
                            <img src="/island_borne_website/static/src/img/hero_desktop.png" alt="Island Borne Cool Smooth Smooth lotion among tropical leaves" fetchpriority="high"/>
                        </picture>
                    </section>

                    <section id="fragrances" class="ib-scent-story ib-section-anchor">
                        <div class="ib-scent-column">
                            <h2 class="ib-script-heading">pick your scent</h2>
                            <div class="ib-scent-blob" aria-label="Island Borne scent choices">
                                <div class="ib-scent-item ib-scent-yummy">
                                    <div class="ib-scent-copy">
                                        <strong>YUMMY</strong>
                                        <span>Vanilla coconut</span>
                                    </div>
                                    <img src="/island_borne_website/static/src/img/yummy_icon.svg" alt="Yummy scent icon" loading="lazy"/>
                                </div>
                                <div class="ib-scent-item ib-scent-cool">
                                    <img src="/island_borne_website/static/src/img/cool_icon.svg" alt="Cool scent icon" loading="lazy"/>
                                    <div class="ib-scent-copy">
                                        <strong>COOL</strong>
                                        <span>Tropical fresh water</span>
                                    </div>
                                </div>
                                <div class="ib-scent-item ib-scent-juicy">
                                    <img src="/island_borne_website/static/src/img/juicy_icon.svg" alt="Juicy scent icon" loading="lazy"/>
                                    <div class="ib-scent-copy">
                                        <strong>JUICY</strong>
                                        <span>Tropical fruity</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="about" class="ib-story-copy ib-story-copy-desktop ib-section-anchor">
                            <h2>AT ISLAND BORNE, WE BELIEVE THAT EVERY BODY AND EVERY BUDGET DESERVES A LITTLE LOVE.</h2>
                            <p>That’s why we create skincare that’s all about feeling good in your own skin, without the hefty price tag.</p>
                            <p>Our products are made for everyday indulgence: rich in moisture, bursting with invigorating fragrances and designed to leave your skin feeling soft and refreshed. We’re here to empower you to step out and shine, starting with how you feel in your skin.</p>
                            <p>Because looking after yourself shouldn’t cost the earth, we’ve wrapped it all up in sustainable packaging you can feel good about too.</p>
                            <p>Island Borne is skincare that keeps it real, feels like a treat and fits into real life.</p>
                        </div>
                    </section>

                    <section id="products" class="ib-products-section ib-section-anchor" aria-labelledby="ib-page-products-heading">
                        <h2 id="ib-page-products-heading" class="visually-hidden">Our Products</h2>
                        <picture class="ib-products-banner">
                            <source media="(max-width: 767px)" srcset="/island_borne_website/static/src/img/products_banner_mobile.png"/>
                            <img src="/island_borne_website/static/src/img/products_banner_desktop.png" alt="Our products: Clean Clean shower gel and Smooth Smooth lotion" loading="lazy"/>
                        </picture>

                        <div class="ib-product-grid">
                            <article class="ib-product-card ib-mobile-order-3">
                                <img src="/island_borne_website/static/src/img/cool_shower.webp" alt="Cool Clean Clean Shower Gel" loading="lazy"/>
                                <h3>COOL</h3><p class="ib-product-name">CLEAN, CLEAN</p><p class="ib-product-type">Shower Gel | 300ml</p>
                            </article>
                            <article class="ib-product-card ib-mobile-order-1">
                                <img src="/island_borne_website/static/src/img/juicy_shower.webp" alt="Juicy Clean Clean Shower Gel" loading="lazy"/>
                                <h3>JUICY</h3><p class="ib-product-name">CLEAN, CLEAN</p><p class="ib-product-type">Shower Gel | 300ml</p>
                            </article>
                            <article class="ib-product-card ib-mobile-order-2">
                                <img src="/island_borne_website/static/src/img/yummy_shower.webp" alt="Yummy Clean Clean Shower Gel" loading="lazy"/>
                                <h3>YUMMY</h3><p class="ib-product-name">CLEAN, CLEAN</p><p class="ib-product-type">Shower Gel | 300ml</p>
                            </article>
                            <article class="ib-product-card ib-mobile-order-5">
                                <img src="/island_borne_website/static/src/img/cool_lotion.webp" alt="Cool Smooth Smooth Lotion" loading="lazy"/>
                                <h3>COOL</h3><p class="ib-product-name">SMOOTH, SMOOTH</p><p class="ib-product-type">Lotion | 300ml</p>
                            </article>
                            <article class="ib-product-card ib-mobile-order-4">
                                <img src="/island_borne_website/static/src/img/juicy_lotion.webp" alt="Juicy Smooth Smooth Lotion" loading="lazy"/>
                                <h3>JUICY</h3><p class="ib-product-name">SMOOTH, SMOOTH</p><p class="ib-product-type">Lotion | 300ml</p>
                            </article>
                            <article class="ib-product-card ib-mobile-order-6">
                                <img src="/island_borne_website/static/src/img/yummy_lotion.webp" alt="Yummy Smooth Smooth Lotion" loading="lazy"/>
                                <h3>YUMMY</h3><p class="ib-product-name">SMOOTH, SMOOTH</p><p class="ib-product-type">Lotion | 300ml</p>
                            </article>
                        </div>
                    </section>

                    <section class="ib-story-copy ib-story-copy-mobile" aria-label="About Island Borne">
                        <h2>AT ISLAND BORNE, WE BELIEVE THAT EVERY BODY AND EVERY BUDGET DESERVES A LITTLE LOVE.</h2>
                        <p>That’s why we create skincare that’s all about feeling good in your own skin, without the hefty price tag.</p>
                        <p>Our products are made for everyday indulgence: rich in moisture, bursting with invigorating fragrances and designed to leave your skin feeling soft and refreshed. We’re here to empower you to step out and shine, starting with how you feel in your skin.</p>
                        <p>Because looking after yourself shouldn’t cost the earth, we’ve wrapped it all up in sustainable packaging you can feel good about too.</p>
                        <p>Island Borne is skincare that keeps it real, feels like a treat and fits into real life.</p>
                    </section>

                    <section id="store-finder" class="ib-store-finder" aria-labelledby="ib-page-store-title">
                        <div class="ib-store-inner">
                            <div class="ib-store-title-row">
                                <h2 id="ib-page-store-title">STORE FINDER</h2>
                                <p>for extra hydration for your skin</p>
                            </div>
                            <div class="ib-store-grid">
                                <div class="ib-store-sidebar">
                                    <form class="ib-store-search" action="#" role="search">
                                        <label class="visually-hidden" for="ib-page-store-search-input">Search for a store</label>
                                        <input id="ib-page-store-search-input" type="search" placeholder="Search for a store..." autocomplete="off"/>
                                        <button type="submit" aria-label="Search stores">
                                            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="10.5" r="5.5"></circle><path d="m15 15 5 5"></path></svg>
                                        </button>
                                    </form>
                                    <div class="ib-store-list" role="list">
                                        <button class="ib-store-card is-active" type="button" data-map-query="Excellent Stores Movie Towne Mall Trinidad" role="listitem">
                                            <span class="ib-pin-icon" aria-hidden="true"><svg viewBox="0 0 24 32"><path d="M12 31S2 19.5 2 11.7C2 5.2 6.4 1 12 1s10 4.2 10 10.7C22 19.5 12 31 12 31z"></path><circle cx="12" cy="11.5" r="3.7"></circle></svg></span>
                                            <span><strong>Excellent Stores<br/>Movie Towne Mall</strong><small>MovieTowne Boulevard, Audrey Jeffers Hwy, Port of Spain</small></span>
                                        </button>
                                        <button class="ib-store-card" type="button" data-map-query="Excellent Stores Trincity Mall Trinidad" role="listitem">
                                            <span class="ib-pin-icon" aria-hidden="true"><svg viewBox="0 0 24 32"><path d="M12 31S2 19.5 2 11.7C2 5.2 6.4 1 12 1s10 4.2 10 10.7C22 19.5 12 31 12 31z"></path><circle cx="12" cy="11.5" r="3.7"></circle></svg></span>
                                            <span><strong>Excellent Stores<br/>Trincity Mall</strong><small>Trincity Central Road, Trincity</small></span>
                                        </button>
                                        <button class="ib-store-card" type="button" data-map-query="Excellent Stores Gulf City Mall Trinidad" role="listitem">
                                            <span class="ib-pin-icon" aria-hidden="true"><svg viewBox="0 0 24 32"><path d="M12 31S2 19.5 2 11.7C2 5.2 6.4 1 12 1s10 4.2 10 10.7C22 19.5 12 31 12 31z"></path><circle cx="12" cy="11.5" r="3.7"></circle></svg></span>
                                            <span><strong>Excellent Stores<br/>Gulf City Mall</strong><small>Gulf City Mall, La Romaine, San Fernando</small></span>
                                        </button>
                                    </div>
                                </div>
                                <div class="ib-map-panel">
                                    <iframe id="ib-store-map" title="Island Borne store map" src="https://www.google.com/maps?q=Excellent%20Stores%20Movie%20Towne%20Mall%20Trinidad&amp;output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                                </div>
                            </div>
                        </div>
                    </section>
                </main>
            </div>
        </t>
    </template>

    <record id="island_borne_homepage_page" model="website.page">
        <field name="name">Island Borne Homepage</field>
        <field name="url">/</field>
        <field name="view_id" ref="island_borne_homepage_page_template"/>
        <field name="is_published">True</field>
        <field name="website_indexed">True</field>
    </record>

    <!-- Make the new published page the actual homepage of the default site. -->
    <record id="website.default_website" model="website">
        <field name="homepage_url">/</field>
    </record>
</odoo>
